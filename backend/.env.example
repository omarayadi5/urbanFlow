APP_ENV=development
APP_NAME=Urban Mobility API
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase connection string.
# Dashboard > Project Settings > Database > Connection string.
# Always replace the leading "postgresql://" with "postgresql+psycopg2://"
# and [YOUR-PASSWORD] with your database password.
#
# Option A - Direct connection (IPv6 only).
# Works out of the box on most Windows machines / networks with IPv6.
# DATABASE_URL=postgresql+psycopg2://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
#
# Option B - Session pooler (IPv4, recommended on macOS or any network
# without IPv6, e.g. "could not translate host name" errors).
# Username has a dot before the project ref: postgres.[YOUR-PROJECT-REF]
DATABASE_URL=postgresql+psycopg2://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Used only if DATABASE_URL is empty
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=
DATABASE_NAME=postgres

JWT_SECRET_KEY=change-me-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
COOKIE_SECURE=false

